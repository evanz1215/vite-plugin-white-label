{
  "name": "vite-plugin-white-label",
  "version": "0.0.5",
  "description": "White-label / multi-brand system for Vite (Vue / React): hard-link shadow directory with brand inheritance (extends) and HMR",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "vite-brand": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "oxlint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "vue",
    "react",
    "white-label",
    "multi-tenant",
    "multi-brand"
  ],
  "license": "0BSD",
  "engines": {
    "node": ">=20.12"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "dependencies": {
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.5",
    "tsup": "^8.3.5",
    "typescript": "^5.5.4",
    "vite": "^6.3.4",
    "vitest": "^3.0.0"
  }
}
